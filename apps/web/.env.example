# ─── Sinan web app env ──────────────────────────────────────────────
# Copy this file to `.env.local` (Next.js auto-loads), or set
# the variables in your deploy environment. `npm run build` and
# `next start` will refuse to start without AUTH_SECRET in
# production; in dev, a hardcoded fallback is used.

# Required in production. Generate with:
#   openssl rand -hex 32
AUTH_SECRET=

# Optional. When set, server actions and API routes that talk
# to Postgres use this DSN. Leave empty in dev if you only need
# the home / ranking / recommendation pages (those fall back to
# mock data when no DB is configured).
DATABASE_URL=

# Optional. NODE_ENV is set automatically by next. Override
# only when needed (e.g. `NODE_ENV=development npm run start`).
# NODE_ENV=production

# Optional. Used by the company-portal E2E tests to bypass
# auth. NOT a real secret in any deployed environment.
PLAYWRIGHT_AUTH_TOKEN=
